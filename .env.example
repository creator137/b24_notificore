APP_ENV=local
APP_TIMEZONE=Europe/Moscow
APP_BASE_URL=https://your-domain.tld/notificore/public
APP_STORAGE_DIR=storage
LOG_PATH=logs/send_log.jsonl

DB_DRIVER=sqlite
DB_DATABASE=storage/notificore.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_CHARSET=utf8mb4

B24_SENDER_CODE=notificore_sms
B24_SENDER_NAME=Notificore SMS
B24_APP_CLIENT_ID=
B24_APP_CLIENT_SECRET=
B24_VERIFY_SSL=true
B24_OAUTH_BASE_URL=https://oauth.bitrix.info/oauth/token

DEV_MODE=true
DEV_INSTALL_MOCK=true
STATUS_CALLBACK_SECRET=

NOTIFICORE_MODE=mock
NOTIFICORE_BASE_URL=https://api.notificore.ru
NOTIFICORE_API_KEY=
NOTIFICORE_AUTH_MODE=x_api_key
NOTIFICORE_REQUEST_FORMAT=json
NOTIFICORE_SMS_SEND_PATH=/rest/sms/create
NOTIFICORE_EMAIL_SEND_PATH=/email/send
NOTIFICORE_API_KEY_HEADER=X-API-KEY
NOTIFICORE_VERIFY_SSL=true
NOTIFICORE_BALANCE_PATH=/rest/common/balance
NOTIFICORE_SMS_STATUS_PATH=/rest/sms/{id}
NOTIFICORE_SMS_STATUS_REFERENCE_PATH=/rest/sms/reference/{reference}

NOTIFICORE_ORIGINATOR=
NOTIFICORE_VALIDITY=72
NOTIFICORE_TARIFF=0
NOTIFICORE_2WAY=0
NOTIFICORE_LOGIN=
NOTIFICORE_PASSWORD=
NOTIFICORE_PROJECT_ID=
